  {
    "name": "Panduan Jurnal Q-Level Peternakan",
    "url": "https://www.scimagojr.com/journalrank.php",
    "type": "static",
    "enabled": true,
    "collection": "Referensi Jurnal Q-Level Peternakan",
    "tags": "jurnal,q-level,quartile,scimago,scopus,sinta,peternakan,animal-science,veterinary",
    "max_items": 1,
