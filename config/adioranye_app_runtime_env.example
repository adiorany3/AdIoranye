# Rekomendasi performa/stabilitas untuk Streamlit Secrets

# Runtime answer profiling
TOKEN_SAVER_ENABLED = true
TOKEN_SAVER_DEFAULT_MODE = "balanced"
MAX_TOKENS_CASUAL = 500
MAX_TOKENS_NORMAL = 1200
MAX_TOKENS_TECHNICAL = 2200
MAX_TOKENS_LONG = 3000
WEB_HISTORY_LIMIT = 6
WEB_HISTORY_RECENT_FULL = 4

# Model routing
SMART_MODEL_ROUTER = true
THINKING_MODEL_ROUTER = true
FAST_NORMAL_MODEL_ROUTER = true
ROTATE_CHEAP_PRIMARY = true
ALLOW_EXPENSIVE_FALLBACK = true
MAX_EXPENSIVE_MODELS = 1
MODEL_REQUEST_TIMEOUT_SECONDS = 45

# Cache and latency
POWER_RESPONSE_CACHE_ENABLED = true
POWER_RESPONSE_CACHE_TTL_SECONDS = 1800
POWER_SEMANTIC_CACHE_ENABLED = true
POWER_SEMANTIC_CACHE_THRESHOLD = 0.78
POWER_LATENCY_BUDGET_ENABLED = true
POWER_CIRCUIT_BREAKER_ENABLED = true

# RAG
POWER_RAG_ENABLED = true
POWER_RAG_TOP_K = 5
POWER_QUERY_REWRITER_ENABLED = true
POWER_RERANKER_ENABLED = true
POWER_RETRIEVAL_EVAL_ENABLED = true

# Current/latest information
AUTO_LIVE_SCRAPING_ENABLED = true
AUTO_LIVE_SCRAPING_MIN_QUERY_CHARS = 8
LIVE_WEB_FALLBACK_ENABLED = true
LIVE_WEB_FALLBACK_PROVIDER = "tavily"
LIVE_WEB_FALLBACK_FORCE_FOR_CURRENT = true
LIVE_WEB_FALLBACK_MAX_RESULTS = 4
LIVE_WEB_FALLBACK_TIMEOUT_SECONDS = 10
LIVE_WEB_FALLBACK_TTL_HOURS = 24
# TAVILY_API_KEY = "isi_api_key_tavily"
