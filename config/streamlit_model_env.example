# Rekomendasi secrets Streamlit untuk model list terbaru.
# Tempel ke Streamlit Community Cloud → App → Settings → Secrets.

SLASHAI_MODEL = "slashai/deepseek-v4-flash-free"
SMART_MODEL_ROUTER = true
FAST_NORMAL_MODEL_ROUTER = true
THINKING_MODEL_ROUTER = true
ALLOW_EXPENSIVE_FALLBACK = true
MAX_SMART_MODELS = 2
MAX_EXPENSIVE_MODELS = 1
RETURN_TO_PRIMARY_MODEL = true
ROTATE_CHEAP_PRIMARY = true

# Health check hemat token.
MODEL_STATUS_AUTO_REFRESH_ENABLED = true
MODEL_HEALTH_QUICK_LIMIT = 4
MODEL_HEALTH_FULL_LIMIT = 18
MODEL_HEALTH_WORKERS = 2
MODEL_HEALTH_RETRIES = 0
MODEL_HEALTH_TIMEOUT_SECONDS = 6
MODEL_HEALTH_PRESERVE_CACHE = true
MODEL_HEALTH_PROBE_MAX_TOKENS = 2
MODEL_HEALTH_PROBE_GPT5_MAX_TOKENS = 8

# Standby/wake-up saver.
STANDBY_HEALTH_SAVER_ENABLED = true
STANDBY_DISABLE_MODEL_DISCOVERY = true
STANDBY_HEALTH_QUICK_LIMIT = 2

# Retry kalau model awal error.
AUTO_RETRY_ON_MODEL_ERROR_ENABLED = true
AUTO_RETRY_ON_MODEL_ERROR_MAX_ATTEMPTS = 3
AUTO_RETRY_ON_MODEL_ERROR_TIMEOUT_SECONDS = 35

# Telegram responsif.
TELEGRAM_MODEL_MODE = "auto"
TELEGRAM_SEND_PROCESSING_MESSAGE = true
TELEGRAM_STATUS_TEST_CACHE_TTL_SECONDS = 21600
TELEGRAM_STATUS_TEST_TIMEOUT_SECONDS = 8
TELEGRAM_AUTO_ROTATE_ON_MODEL_ERROR = true
TELEGRAM_SHOW_MODEL_INFO = true
